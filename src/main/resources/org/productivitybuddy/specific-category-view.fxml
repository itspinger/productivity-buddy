<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.productivitybuddy.controller.SpecificCategoryController"
      spacing="16"
      styleClass="surface-card">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="backButton" onAction="#onBack" styleClass="icon-button"/>
        <Label fx:id="headerLabel" styleClass="view-title"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="8" prefWidth="430">
            <Label text="Processes" styleClass="section-title"/>
            <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Process" prefWidth="160"/>
                    <TableColumn fx:id="resourceColumn" text="RAM &amp; CPU" prefWidth="150"/>
                    <TableColumn fx:id="timeColumn" text="Time" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12" alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
            <Label text="Top 10 processes by time spent" styleClass="section-title"/>
            <PieChart fx:id="top10Chart" legendVisible="false" prefHeight="320" prefWidth="420"/>
            <Label fx:id="totalTimeLabel" styleClass="body-title"/>
        </VBox>
    </HBox>
</VBox>
