<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@toggle-switch.css"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.productivitybuddy.controller.MainViewController">

    <top>
        <fx:include source="toolbar.fxml" fx:id="toolbar"/>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets bottom="10" left="10" right="10" top="5"/>
            </padding>

            <HBox fx:id="splitView" spacing="10">
                <VBox fx:id="processPanel" prefWidth="340" spacing="5">
                    <TextField fx:id="searchField" promptText="Search processes..."/>
                    <TableView fx:id="processTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="processNameColumn" text="Process" prefWidth="200"/>
                            <TableColumn fx:id="processCategoryColumn" text="Category" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox fx:id="rightPanel" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets topRightBottomLeft="10"/>
                    </padding>
                </VBox>
            </HBox>

            <VBox fx:id="fullWidthHost" visible="false" managed="false" spacing="10"/>
        </StackPane>
    </center>

</BorderPane>
