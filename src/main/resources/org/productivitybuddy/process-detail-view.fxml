<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="org.productivitybuddy.controller.ProcessDetailController"
    spacing="15">
    <padding>
        <Insets topRightBottomLeft="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Button text="&#x2190;"
            style="-fx-background-color: transparent; -fx-font-size: 24; -fx-text-fill: #007AFF; -fx-cursor: hand; -fx-padding: 0;"
            onAction="#onBack"/>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER" spacing="8">
            <Label fx:id="nameLabel" style="-fx-font-size: 16; -fx-font-weight: normal;"/>
            <Label fx:id="totalTimeLabel" style="-fx-font-size: 14;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <GridPane hgap="20" vgap="8" alignment="CENTER">
        <padding>
            <Insets top="10" bottom="10"/>
        </padding>
        <VBox spacing="5" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label fx:id="ramLabel" style="-fx-font-size: 14;"/>
            <Label fx:id="ramRankLabel" style="-fx-font-size: 12; -fx-text-fill: gray;"/>
        </VBox>
        <VBox spacing="5" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label fx:id="cpuLabel" style="-fx-font-size: 14;"/>
            <Label fx:id="cpuRankLabel" style="-fx-font-size: 12; -fx-text-fill: gray;"/>
        </VBox>
    </GridPane>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Button text="Kill Process" prefWidth="140" onAction="#onKill"
            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button text="Change Name" prefWidth="140" onAction="#onChangeName"
            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button fx:id="freezeButton" text="Freeze Tracking" prefWidth="140" onAction="#onToggleFreeze"
            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button text="Change Category" prefWidth="140" onAction="#onChangeCategory"
            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>
</VBox>
