<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="org.productivitybuddy.controller.ProcessDetailController"
    spacing="15"
    styleClass="surface-card">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Button fx:id="backButton" onAction="#onBack" styleClass="icon-button"/>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER" spacing="8">
            <Label fx:id="nameLabel" styleClass="view-title"/>
            <Label fx:id="totalTimeLabel" styleClass="body-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <GridPane hgap="20" vgap="8" alignment="CENTER">
        <padding>
            <Insets top="10" bottom="10"/>
        </padding>
        <VBox spacing="5" alignment="CENTER" styleClass="summary-row" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label fx:id="ramLabel" styleClass="metric-label"/>
            <Label fx:id="ramRankLabel" styleClass="secondary-text"/>
        </VBox>
        <VBox spacing="5" alignment="CENTER" styleClass="summary-row" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label fx:id="cpuLabel" styleClass="metric-label"/>
            <Label fx:id="cpuRankLabel" styleClass="secondary-text"/>
        </VBox>
    </GridPane>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Button fx:id="killButton" text="Kill Process" prefWidth="160" onAction="#onKill" styleClass="button-danger"
            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button fx:id="changeNameButton" text="Change Name" prefWidth="160" onAction="#onChangeName"
            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button fx:id="freezeButton" text="Freeze Tracking" prefWidth="160" onAction="#onToggleFreeze"
            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button fx:id="changeCategoryButton" text="Change Category" prefWidth="160" onAction="#onChangeCategory"
            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>
</VBox>
